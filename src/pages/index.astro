---
import { profile } from '../data/profile';
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Oliver Oliveira</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Architects+Daughter&family=JetBrains+Mono:wght@400;700;800&family=Francois+One&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="grain"></div>

  <header class="hero">
    <div class="hero-grid">
      <div class="hero-name-block">
        <div class="stencil-label">FULL STACK DEVELOPER</div>
        <h1 class="hero-name">OLIVER<br/><span class="surname">OLIVEIRA</span></h1>
        <div class="hero-meta">
          <span class="meta-item"><span class="meta-label">LOC</span> {profile.location}</span>
          <span class="meta-item"><span class="meta-label">MAIL</span> <a href="mailto:{profile.email}">{profile.email}</a></span>
          <span class="meta-item"><span class="meta-label">WEB</span> <a href="{profile.linkedin}" target="_blank">linkedin</a></span>
        </div>
      </div>
      <div class="hero-tagline-block">
        <div class="concrete-slab">
          <p>{profile.tagline}</p>
        </div>
      </div>
    </div>
    <div class="hero-rule"></div>
  </header>

  <section class="section" id="experience">
    <h2 class="section-title"><span class="section-num">01</span> WORK</h2>
    <div class="section-rule"></div>
    {profile.experience.map((exp, i) => (
      <article class="job" style={`--i: ${i}`}>
        <div class="job-header">
          <h3 class="job-role">{exp.role}</h3>
          <span class="job-company">{exp.company}</span>
          <span class="job-period">{exp.period}</span>
        </div>
        <ul class="job-highlights">
          {exp.highlights.map((h) => (
            <li>{h}</li>
          ))}
        </ul>
      </article>
    ))}
  </section>

  <section class="section" id="skills">
    <h2 class="section-title"><span class="section-num">02</span> ARSENAL</h2>
    <div class="section-rule"></div>
    <div class="skills-grid">
      <div class="skill-block">
        <h4>Languages</h4>
        <div class="skill-tags">{profile.skills.languages.map((s) => (
          <span class="tag">{s}</span>
        ))}</div>
      </div>
      <div class="skill-block">
        <h4>Frontend</h4>
        <div class="skill-tags">{profile.skills.frontend.map((s) => (
          <span class="tag">{s}</span>
        ))}</div>
      </div>
      <div class="skill-block">
        <h4>Backend</h4>
        <div class="skill-tags">{profile.skills.backend.map((s) => (
          <span class="tag">{s}</span>
        ))}</div>
      </div>
      <div class="skill-block">
        <h4>Testing</h4>
        <div class="skill-tags">{profile.skills.testing.map((s) => (
          <span class="tag">{s}</span>
        ))}</div>
      </div>
      <div class="skill-block">
        <h4>Infrastructure</h4>
        <div class="skill-tags">{profile.skills.infrastructure.map((s) => (
          <span class="tag">{s}</span>
        ))}</div>
      </div>
    </div>
  </section>

  <section class="section" id="education">
    <h2 class="section-title"><span class="section-num">03</span> EDUCATION</h2>
    <div class="section-rule"></div>
    <div class="edu-block">
      <span class="edu-degree">{profile.education.degree}</span>
      <span class="edu-institution">{profile.education.institution}</span>
      <span class="edu-period">{profile.education.period}</span>
    </div>
  </section>

  <section class="section" id="certifications">
    <h2 class="section-title"><span class="section-num">04</span> CERTS</h2>
    <div class="section-rule"></div>
    <div class="cert-list">
      {profile.certifications.map((cert) => (
        <span class="cert-item">{cert}</span>
      ))}
    </div>
  </section>

  <footer class="footer">
    <div class="footer-rule"></div>
    <div class="footer-content">
      <span>© 2026 OLIVER OLIVEIRA</span>
      <span>BUILT WITH EXPOSED STRUCTURE</span>
    </div>
  </footer>
</body>
</html>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Architects+Daughter&family=JetBrains+Mono:wght@400;700;800&family=Francois+One&display=swap');

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --concrete: #c8c0b8;
    --concrete-dark: #a39e97;
    --concrete-darker: #7a756f;
    --rust: #c4451c;
    --rust-light: #e8613a;
    --ink: #1a1816;
    --ink-light: #2d2a27;
    --grout: #3a3632;
    --chalk: #f0ece6;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background: var(--ink);
    color: var(--concrete);
    font-family: 'JetBrains Mono', monospace;
    line-height: 1.7;
    overflow-x: hidden;
    position: relative;
  }

  .grain {
    position: fixed;
    inset: 0;
    opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px;
    pointer-events: none;
    z-index: 1000;
    mix-blend-mode: overlay;
  }

  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 5vw;
    border-left: 4px solid var(--rust);
    position: relative;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(200, 192, 184, 0.015) 2px,
      rgba(200, 192, 184, 0.015) 4px
    );
    pointer-events: none;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 4rem;
    align-items: end;
  }

  .stencil-label {
    font-family: 'Francois One', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: var(--rust);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    padding: 0.3rem 0;
    border-top: 2px solid var(--rust);
    border-bottom: 2px solid var(--rust);
    display: inline-block;
    animation: labelSlide 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.5s;
  }

  @keyframes labelSlide {
    from { opacity: 0; transform: translateX(-30px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .hero-name {
    font-family: 'Francois One', sans-serif;
    font-size: clamp(3.5rem, 8vw, 8rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--chalk);
    text-transform: uppercase;
    animation: nameReveal 1s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.2s;
  }

  @keyframes nameReveal {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .surname {
    color: var(--rust);
  }

  .hero-meta {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    animation: metaFade 0.8s ease both;
    animation-delay: 1s;
  }

  @keyframes metaFade {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .meta-item {
    font-size: 0.72rem;
    color: var(--concrete-dark);
    letter-spacing: 0.05em;
  }

  .meta-label {
    color: var(--rust);
    font-weight: 700;
    margin-right: 0.4em;
  }

  .meta-item a {
    color: var(--concrete-dark);
    text-decoration: none;
    border-bottom: 1px solid var(--grout);
    transition: color 0.2s, border-color 0.2s;
  }

  .meta-item a:hover {
    color: var(--rust-light);
    border-bottom-color: var(--rust-light);
  }

  .hero-tagline-block {
    animation: taglineSlide 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.7s;
  }

  @keyframes taglineSlide {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .concrete-slab {
    background: var(--ink-light);
    border-left: 3px solid var(--rust);
    padding: 1.8rem 2rem;
    position: relative;
  }

  .concrete-slab::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 40px;
    height: 40px;
    border-top: 2px dashed var(--grout);
    border-left: 2px dashed var(--grout);
  }

  .concrete-slab::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40px;
    height: 40px;
    border-bottom: 2px dashed var(--grout);
    border-right: 2px dashed var(--grout);
  }

  .concrete-slab p {
    font-size: 0.82rem;
    line-height: 1.8;
    color: var(--concrete-dark);
  }

  .hero-rule {
    margin-top: 4rem;
    height: 2px;
    background: repeating-linear-gradient(90deg, var(--grout) 0, var(--grout) 8px, transparent 8px, transparent 14px);
  }

  .style-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.2rem 5vw;
    background: var(--ink-light);
    border-left: 4px solid var(--rust);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .back-link {
    color: var(--rust);
    text-decoration: none;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--rust-light);
  }

  .style-label {
    font-family: 'Architects Daughter', cursive;
    font-size: 0.65rem;
    color: var(--concrete-darker);
    letter-spacing: 0.15em;
  }

  .section {
    padding: 5rem 5vw 3rem;
    border-left: 4px solid var(--rust);
    position: relative;
  }

  .section::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: linear-gradient(to bottom, var(--rust), transparent);
    opacity: 0.3;
  }

  .section-title {
    font-family: 'Francois One', sans-serif;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 800;
    color: var(--chalk);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-bottom: 0.5rem;
  }

  .section-num {
    color: var(--rust);
    font-size: 0.8em;
    margin-right: 0.3em;
  }

  .section-rule {
    height: 2px;
    background: repeating-linear-gradient(90deg, var(--grout) 0, var(--grout) 6px, transparent 6px, transparent 10px);
    margin-bottom: 3rem;
  }

  .job {
    margin-bottom: 3.5rem;
    padding-left: 2rem;
    border-left: 2px solid var(--grout);
    position: relative;
    animation: jobReveal 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: calc(var(--i) * 0.15s);
  }

  @keyframes jobReveal {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .job::before {
    content: '';
    position: absolute;
    left: -5px;
    top: 0;
    width: 8px;
    height: 8px;
    background: var(--rust);
  }

  .job-header {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    gap: 0.2rem 1.5rem;
    margin-bottom: 1rem;
  }

  .job-role {
    font-family: 'Francois One', sans-serif;
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--chalk);
    text-transform: uppercase;
  }

  .job-company {
    font-size: 0.75rem;
    color: var(--rust);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    align-self: end;
  }

  .job-period {
    font-size: 0.7rem;
    color: var(--concrete-darker);
    grid-column: 1 / -1;
  }

  .job-highlights {
    list-style: none;
  }

  .job-highlights li {
    font-size: 0.78rem;
    line-height: 1.75;
    color: var(--concrete-dark);
    padding-left: 1.2rem;
    position: relative;
    margin-bottom: 0.3rem;
  }

  .job-highlights li::before {
    content: '//';
    position: absolute;
    left: 0;
    color: var(--rust);
    font-weight: 700;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
  }

  .skill-block h4 {
    font-family: 'Francois One', sans-serif;
    font-size: 0.8rem;
    color: var(--rust);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 0.8rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--grout);
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    padding: 0.35rem 0.8rem;
    background: var(--ink-light);
    border: 1px solid var(--grout);
    font-size: 0.7rem;
    color: var(--concrete);
    letter-spacing: 0.05em;
    transition: border-color 0.2s, color 0.2s;
  }

  .tag:hover {
    border-color: var(--rust);
    color: var(--chalk);
  }

  .edu-block {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    align-items: baseline;
  }

  .edu-degree {
    font-family: 'Francois One', sans-serif;
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--chalk);
    text-transform: uppercase;
  }

  .edu-institution {
    font-size: 0.78rem;
    color: var(--concrete-dark);
  }

  .edu-period {
    font-size: 0.7rem;
    color: var(--rust);
    letter-spacing: 0.1em;
  }

  .cert-list {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .cert-item {
    padding: 0.6rem 1.2rem;
    border: 2px solid var(--rust);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--rust);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: background 0.2s, color 0.2s;
  }

  .cert-item:hover {
    background: var(--rust);
    color: var(--chalk);
  }

  .footer {
    padding: 3rem 5vw;
  }

  .footer-rule {
    height: 2px;
    background: repeating-linear-gradient(90deg, var(--grout) 0, var(--grout) 6px, transparent 6px, transparent 10px);
    margin-bottom: 1.5rem;
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    font-size: 0.6rem;
    color: var(--concrete-darker);
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .hero { padding: 3rem 1.5rem; }
    .section { padding: 3rem 1.5rem 2rem; }
    .style-nav { padding: 1rem 1.5rem; }
    .job-header {
      grid-template-columns: 1fr;
    }
    .hero-meta { gap: 1rem; }
    .skills-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 480px) {
    .skills-grid { grid-template-columns: 1fr; }
  }
</style>